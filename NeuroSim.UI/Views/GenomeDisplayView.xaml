<UserControl x:Class="NeuroSim.UI.Views.GenomeDisplayView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:NeuroSim.UI.Models"
             Loaded="OnLoaded">

    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#475569"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#0D0D16" BorderBrush="#1E293B"
            BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,16">
        <StackPanel>
            <TextBlock Text="{Binding Title}" Style="{StaticResource Lbl}"/>
            <TextBlock Text="{Binding DisplayText}" Foreground="#94A3B8" FontSize="11"
                       FontFamily="Consolas" TextWrapping="Wrap" LineHeight="18"
                       Margin="0,0,0,8"/>
            <!-- Graph: edge list when available -->
            <ItemsControl x:Name="GraphEdgesCtrl" Visibility="Collapsed"
                          ItemsSource="{Binding GraphEdgesForDisplay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:EdgeDisplayItem">
                        <TextBlock Foreground="#64748B" FontSize="10" FontFamily="Consolas"
                                   Margin="0,0,0,2">
                            <Run Text="{Binding From}"/>
                            <Run Text=" → "/>
                            <Run Text="{Binding To}"/>
                            <Run Text=" (weight: "/>
                            <Run Text="{Binding Weight, StringFormat=F2}"/>
                            <Run Text=")"/>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <TextBlock Foreground="#334155" FontSize="9" Margin="0,4,0,0">
                <Run Text="Type:"/>
                <Run Text="{Binding DisplayType}" FontWeight="SemiBold"/>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>
