<!-- AUTH:DEVNEUROSIM:7A3F9E2B | Legacy/NeuroSim.UI/Views/GraphPlaygroundView.xaml -->
<UserControl x:Class="NeuroSim.UI.Views.GraphPlaygroundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:NeuroSim.UI.Views"
             Background="{StaticResource BackgroundBrush}" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ─────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="{StaticResource CardDarkBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,9">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🕸 " FontSize="15" VerticalAlignment="Center"/>
                    <TextBlock Text="Graph / DAG Evolution" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                    <Border Margin="12,2,0,0" Background="#0A38BDF8"
                            BorderBrush="{StaticResource InfoBrush}" BorderThickness="1" CornerRadius="4" Padding="6,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="GA  ·  GRAPH GENOME" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource InfoBrush}"/>
                    </Border>
                    <Border Margin="8,2,0,0" Background="#0AFFFFFF"
                            BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding ModeLabel}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="⇌  Toggle Mode" Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding ToggleModeCommand}"/>
                    <Button Content="▶  Evolve"   Style="{StaticResource PrimaryButton}" Margin="0,0,6,0" Command="{Binding RunCommand}"/>
                    <Button Content="■  Stop"     Style="{StaticResource DangerButton}"  Margin="0,0,6,0" Command="{Binding StopCommand}"/>
                    <Button Content="↺  Reset"    Style="{StaticResource OutlineButton}" Margin="0,0,6,0" Command="{Binding ResetCommand}"/>
                    <Button Content="🗑 Clear"    Style="{StaticResource GhostButton}"   Command="{Binding ClearCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>  <!-- config -->
                <ColumnDefinition Width="*"/>    <!-- editor canvas -->
                <ColumnDefinition Width="260"/>  <!-- chart + legend -->
            </Grid.ColumnDefinitions>

            <!-- Config panel -->
            <Border Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14">

                        <TextBlock Style="{StaticResource Label}" Text="GA CONFIG" Margin="0,0,0,8"/>
                        <TextBlock Style="{StaticResource Label}" Text="POPULATION SIZE" Margin="0,0,0,5"/>
                        <TextBox Text="{Binding PopulationSize, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Style="{StaticResource Label}" Text="MAX GENERATIONS" Margin="0,10,0,5"/>
                        <TextBox Text="{Binding MaxGenerations, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="{Binding MutationRate, StringFormat='MUTATION RATE  {0:P0}'}"
                                   Style="{StaticResource Label}" Margin="0,10,0,5"/>
                        <Slider Value="{Binding MutationRate}" Minimum="0.02" Maximum="0.4"/>

                        <Separator Margin="0,12"/>
                        <TextBlock Style="{StaticResource Label}" Text="GRAPH INFO" Margin="0,0,0,8"/>
                        <Border Style="{StaticResource StatBadge}" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="STRUCTURE" Style="{StaticResource Label}"/>
                                <TextBlock Text="{Binding EdgeInfo}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource InfoBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBadge}" Margin="0,0,0,6">
                            <StackPanel>
                                <TextBlock Text="GENERATION" Style="{StaticResource Label}"/>
                                <TextBlock Text="{Binding CurrentGeneration}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource AccentLightBrush}"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatBadge}">
                            <StackPanel>
                                <TextBlock Text="BEST SCORE" Style="{StaticResource Label}"/>
                                <TextBlock Text="{Binding BestScore}" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,12"/>
                        <TextBlock Style="{StaticResource Label}" Text="EDITING" Margin="0,0,0,8"/>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap">
                            <Run Text="Click empty"/>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" Text=" — add node"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                            <Run Text="Drag node"/>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" Text=" — move it"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                            <Run Text="Edge mode:"/>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" Text=" drag A→B adds edge"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,3,0,0">
                            <Run Text="Right-click"/>
                            <Run Foreground="{StaticResource TextSecondaryBrush}" Text=" — remove node"/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Interactive DAG canvas -->
            <Border Grid.Column="1" Background="#FF0A0A0F"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <TextBlock Text="{Binding Status}"
                               HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                    <local:DagEditorCanvas x:Name="DagCanvas"
                                           DataContext="{Binding}"
                                           Nodes="{Binding Nodes}"
                                           Edges="{Binding Edges}"
                                           EvolvedEdges="{Binding EvolvedEdges}"
                                           IsEditable="{Binding IsEditable}"
                                           AddEdgeMode="{Binding AddEdgeMode}"
                                           Margin="12"/>
                </Grid>
            </Border>

            <!-- Right: fitness chart + legend -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <oxy:PlotView Model="{Binding FitnessPlot}" Background="Transparent"/>

                <!-- Legend -->
                <StackPanel Grid.Row="1" Margin="12,8,12,12">
                    <TextBlock Style="{StaticResource Label}" Text="LEGEND" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="24" Height="3" Background="{StaticResource AccentLightBrush}" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="User-drawn edges" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="24" Height="3" Background="{StaticResource InfoBrush}" CornerRadius="1" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Evolved best graph" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Margin="0,8,0,0" FontSize="10" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"
                               Text="Objective: maximise directed edges in a DAG (no symmetric cycles). Edge-toggle mutation + uniform crossover."/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
