<!-- AUTH:DEVNEUROSIM:7A3F9E2B | Legacy/NeuroSim.UI/Views/ProblemSelectorView.xaml -->
<UserControl x:Class="NeuroSim.UI.Views.ProblemSelectorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}" FontFamily="Segoe UI">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="48,40">

            <TextBlock Text="Choose a Problem" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
            <TextBlock Text="Select a built-in benchmark problem to simulate."
                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" Margin="0,0,0,32"/>

            <UniformGrid Columns="3" Rows="1">

                <!-- TSP -->
                <Border Margin="0,0,12,0" CornerRadius="8"
                        Background="#FF111116" BorderBrush="#FF2A2A3A" BorderThickness="1" Cursor="Hand">
                    <Border.Style><Style TargetType="Border"><Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/></Trigger>
                    </Style.Triggers></Style></Border.Style>
                    <StackPanel Margin="24,24,24,20">
                        <Border Width="40" Height="40" CornerRadius="6" Background="#11FFFFFF"
                                BorderBrush="#FF333333" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="TSP" FontSize="11" FontWeight="Bold" Foreground="#FF94A3B8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Traveling Salesperson" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="PERMUTATION GENOME  ·  ORDER CROSSOVER  ·  2-OPT MUTATION"
                                   FontSize="9" FontWeight="SemiBold" Foreground="#FF475569" Margin="0,0,0,10"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                   Text="Find the shortest route visiting all cities exactly once. Drag to reposition cities, click to add new ones. Watch the GA shorten the tour in real time."/>
                        <Button Content="Open TSP  →" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Margin="0,18,0,0" FontSize="12" Padding="16,7"
                                Command="{Binding OpenTspCommand}"/>
                    </StackPanel>
                </Border>

                <!-- CSP -->
                <Border Margin="6,0,6,0" CornerRadius="8"
                        Background="#FF111116" BorderBrush="#FF2A2A3A" BorderThickness="1" Cursor="Hand">
                    <Border.Style><Style TargetType="Border"><Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{StaticResource SuccessBrush}"/></Trigger>
                    </Style.Triggers></Style></Border.Style>
                    <StackPanel Margin="24,24,24,20">
                        <Border Width="40" Height="40" CornerRadius="6" Background="#11FFFFFF"
                                BorderBrush="#FF333333" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="CSP" FontSize="11" FontWeight="Bold" Foreground="#FF94A3B8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Bin Packing / CSP" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="PERMUTATION GENOME  ·  RELOCATE MUTATION  ·  FFD DECODER"
                                   FontSize="9" FontWeight="SemiBold" Foreground="#FF475569" Margin="0,0,0,10"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                   Text="Pack items of varying sizes into the fewest bins without exceeding capacity. Live bin-fill chart shows packing quality evolving."/>
                        <Button Content="Open CSP  →" Style="{StaticResource OutlineButton}"
                                HorizontalAlignment="Left" Margin="0,18,0,0" FontSize="12" Padding="16,7"
                                Command="{Binding OpenCspCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Graph -->
                <Border Margin="12,0,0,0" CornerRadius="8"
                        Background="#FF111116" BorderBrush="#FF2A2A3A" BorderThickness="1" Cursor="Hand">
                    <Border.Style><Style TargetType="Border"><Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{StaticResource InfoBrush}"/></Trigger>
                    </Style.Triggers></Style></Border.Style>
                    <StackPanel Margin="24,24,24,20">
                        <Border Width="40" Height="40" CornerRadius="6" Background="#11FFFFFF"
                                BorderBrush="#FF333333" BorderThickness="1" HorizontalAlignment="Left" Margin="0,0,0,12">
                            <TextBlock Text="DAG" FontSize="11" FontWeight="Bold" Foreground="#FF94A3B8"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Graph / DAG Evolution" FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,0,0,4"/>
                        <TextBlock Text="GRAPH GENOME  ·  EDGE-TOGGLE MUTATION  ·  UNIFORM CROSSOVER"
                                   FontSize="9" FontWeight="SemiBold" Foreground="#FF475569" Margin="0,0,0,10"/>
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"
                                   Text="Draw nodes and directed edges on a canvas. Run the GA to evolve a maximum-edge DAG. See the evolved graph overlaid in blue."/>
                        <Button Content="Open Graph  →" Style="{StaticResource OutlineButton}"
                                HorizontalAlignment="Left" Margin="0,18,0,0" FontSize="12" Padding="16,7"
                                Command="{Binding OpenGraphCommand}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
