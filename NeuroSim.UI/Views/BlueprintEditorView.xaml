<!-- AUTH:DEVNEUROSIM:7A3F9E2B | Legacy/NeuroSim.UI/Views/BlueprintEditorView.xaml -->
<UserControl x:Class="NeuroSim.UI.Views.BlueprintEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:NeuroSim.UI.ViewModels"
             xmlns:conv="clr-namespace:NeuroSim.UI.Converters"
             xmlns:bp="clr-namespace:NeuroSim.UI.Models.Blueprint"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <conv:ConnectionToPathConverter x:Key="ConnectionToPath"/>
        <conv:CountToVisibilityConverter x:Key="CountToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:ObjectToStringConverter x:Key="ObjectToString"/>
        <conv:EqualToBrushConverter x:Key="SelectedBorder" SelectedBrush="{StaticResource AccentBrush}" DefaultBrush="{StaticResource BorderBrush}"/>
        <Style x:Key="BlockPaletteItem" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BlockNodeStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <MultiBinding Converter="{StaticResource SelectedBorder}">
                        <Binding Path="DataContext.SelectedNode" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                        <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                    </MultiBinding>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinWidth" Value="140"/>
            <Setter Property="Cursor" Value="SizeAll"/>
        </Style>
        <Style x:Key="PortEllipse" TargetType="Ellipse">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Stroke" Value="{StaticResource AccentLightBrush}"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Setter Property="Cursor" Value="Cross"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="200" MinWidth="160" MaxWidth="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT: Block palette (categorical) ═══ -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,12,12,20">
                    <TextBlock Text="BLOCKS" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding BlockCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:BlockCategory}">
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Text="{Binding Name}" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentLightBrush}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Blocks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type bp:BlockDefinition}">
                                                <Border Style="{StaticResource BlockPaletteItem}"
                                                        MouseLeftButtonDown="BlockPalette_MouseLeftButtonDown">
                                                    <Border.Tag>
                                                        <Binding RelativeSource="{RelativeSource Self}" Path="DataContext"/>
                                                    </Border.Tag>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="9"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="180"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Clear canvas" Style="{StaticResource GhostButton}"
                            Command="{Binding ClearCanvasCommand}" Margin="0,16,0,0" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}" Opacity="0.5"/>

        <!-- ═══ CENTER: Canvas ═══ -->
        <Border Grid.Column="2" Background="#0D0D12" ClipToBounds="True">
            <Grid>
                <ScrollViewer x:Name="CanvasScroll" HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              AllowDrop="True" Drop="Canvas_Drop" DragOver="Canvas_DragOver">
                    <Canvas x:Name="NodeCanvas" MinWidth="2000" MinHeight="1500"
                            Background="#0A0A0F" Margin="20">
                        <!-- Connection paths (behind nodes) -->
                        <ItemsControl ItemsSource="{Binding Connections}" Panel.ZIndex="0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type bp:BlueprintConnection}">
                                    <Path Stroke="{StaticResource AccentBrush}" StrokeThickness="2"
                                          Panel.ZIndex="0">
                                        <Path.Data>
                                            <MultiBinding Converter="{StaticResource ConnectionToPath}">
                                                <Binding Path="SourceNode.X"/>
                                                <Binding Path="SourceNode.Y"/>
                                                <Binding Path="TargetNode.X"/>
                                                <Binding Path="TargetNode.Y"/>
                                            </MultiBinding>
                                        </Path.Data>
                                    </Path>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="0"/>
                                    <Setter Property="Canvas.Top" Value="0"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                        </ItemsControl>
                        <!-- Nodes (draggable) -->
                        <ItemsControl ItemsSource="{Binding Nodes}" Panel.ZIndex="1">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type bp:BlueprintNode}">
                                    <Border Style="{StaticResource BlockNodeStyle}"
                                            MouseLeftButtonDown="BlockNode_MouseLeftButtonDown"
                                            MouseLeftButtonUp="BlockNode_MouseLeftButtonUp"
                                            MouseMove="BlockNode_MouseMove">
                                        <Border.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Delete" Click="BlockNode_Delete_Click"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Input ports -->
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="-8,0,8,0">
                                                <ItemsControl ItemsSource="{Binding Definition.Inputs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type bp:PortDefinition}">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                                                         ToolTip="Input: drag from an output port to here">
                                                                <Ellipse Style="{StaticResource PortEllipse}"
                                                                         MouseLeftButtonDown="InputPort_MouseLeftButtonDown"
                                                                         MouseLeftButtonUp="InputPort_MouseLeftButtonUp"/>
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="9"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                            <!-- Block title -->
                                            <TextBlock Grid.Column="1" Text="{Binding Definition.DisplayName}"
                                                       FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            <!-- Output ports -->
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0,-8,0">
                                                <ItemsControl ItemsSource="{Binding Definition.Outputs}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type bp:PortDefinition}">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                                                                         ToolTip="Output: drag from here to an input port">
                                                                <TextBlock Text="{Binding DisplayName}" FontSize="9"
                                                                           Foreground="{StaticResource TextMutedBrush}"
                                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                <Ellipse Style="{StaticResource PortEllipse}"
                                                                         MouseLeftButtonDown="OutputPort_MouseLeftButtonDown"
                                                                         MouseLeftButtonUp="OutputPort_MouseLeftButtonUp"/>
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </ScrollViewer>
                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,24,0,0"
                           Foreground="{StaticResource TextMutedBrush}" FontSize="12"
                           Visibility="{Binding Nodes.Count, Converter={StaticResource CountToVisibility}}"
                           Panel.ZIndex="2">
                    <Run Text="Drag blocks from the left. "/>
                    <Run Text="To connect: click and drag from output port ● (right) to input port ● (left)." FontWeight="SemiBold"/>
                </TextBlock>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch"
                      Background="{StaticResource BorderBrush}" Opacity="0.5"/>

        <!-- ═══ RIGHT: Properties panel (when block selected) ═══ -->
        <Border Grid.Column="4" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding SelectedNode, Converter={StaticResource NullToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12,12,12,20">
                    <TextBlock Text="PROPERTIES" FontSize="10" FontWeight="SemiBold"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding SelectedNode.Definition.DisplayName, FallbackValue='—'}"
                               FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ItemsControl ItemsSource="{Binding ConfigEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type bp:BlockConfigEntry}">
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="10"
                                               Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                                    <TextBox Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                                             BorderBrush="{StaticResource BorderBrush}" Padding="8,6" FontSize="12"
                                             Text="{Binding Value, Converter={StaticResource ObjectToString}, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
