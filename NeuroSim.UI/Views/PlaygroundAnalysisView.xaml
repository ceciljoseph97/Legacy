<UserControl x:Class="NeuroSim.UI.Views.PlaygroundAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:models="clr-namespace:NeuroSim.UI.Models">

    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#475569"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="#111118"/>
            <Setter Property="BorderBrush"     Value="#252535"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="6"/>
            <Setter Property="Padding"         Value="10,8"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#09090F">
        <StackPanel Margin="16">

            <!-- Stat badges -->
            <TextBlock Text="CURRENT METRICS" Foreground="#475569" FontSize="10"
                       FontWeight="SemiBold" Margin="0,0,0,10"/>
            <ItemsControl x:Name="StatBadgesCtrl" Margin="0,0,0,18">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="4"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:StatBadge">
                        <Border Style="{StaticResource StatCard}" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="{Binding Label}" Foreground="#64748B" FontSize="9" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Value}" Foreground="#F1F5F9" FontSize="20" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SubLabel}" Foreground="#334155" FontSize="9"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Charts with Export -->
            <ItemsControl x:Name="ChartsCtrl">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:ChartSlot">
                        <StackPanel Margin="0,0,0,20">
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="{Binding Title}" Style="{StaticResource Lbl}"
                                           VerticalAlignment="Center"/>
                                <Button Content="💾 Export PNG" HorizontalAlignment="Right"
                                        Tag="{Binding}" Padding="8,4" FontSize="10"
                                        Click="OnExportChartClick"
                                        Background="Transparent" Foreground="#64748B"
                                        BorderThickness="0" Cursor="Hand"/>
                            </Grid>
                            <Border BorderBrush="#1E293B" BorderThickness="1" CornerRadius="4" Height="260">
                                <oxy:PlotView Model="{Binding Plot}" Background="#09090F"/>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Extra content slot (parent can add via ContentProperty or binding) -->
            <ContentPresenter x:Name="ExtraPresenter"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
