<!-- AUTH:DEVNEUROSIM:7A3F9E2B | Legacy/NeuroSim.UI/Views/HomePage.xaml -->
<UserControl x:Class="NeuroSim.UI.Views.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             FontFamily="Segoe UI"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>

            <!-- ── Hero ─────────────────────────────────────────────────── -->
            <Border Background="#FF0A0A0F" Padding="56,44,56,40">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="◈ " FontSize="30" Foreground="{StaticResource AccentLightBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="NeuroSim" FontSize="32" FontWeight="Bold"
                                       Foreground="White"/>
                        </StackPanel>
                        <TextBlock Text="Evolutionary Computation Simulation Framework"
                                   FontSize="15" Foreground="#FF94A3B8" Margin="0,4,0,0"/>
                        <TextBlock FontSize="13" Foreground="#FF475569" Margin="0,8,0,0"
                                   TextWrapping="Wrap" MaxWidth="540"
                                   Text="Simulate the four canonical forms of Evolutionary Computation — run live experiments on standard benchmark problems, visualise populations evolving in real time."/>

                        <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                            <Button Content="▶  Open TSP Playground"
                                    Style="{StaticResource PrimaryButton}"
                                    FontSize="13" Padding="20,9"
                                    Command="{Binding GoToTspCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- version badge -->
                    <Border Grid.Column="1" VerticalAlignment="Top"
                            Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1"
                            CornerRadius="6" Padding="12,6">
                        <TextBlock Text="v 1.0 — research build" FontSize="10"
                                   Foreground="#FF475569"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Thin divider ─────────────────────────────────────────── -->
            <Border Height="1" Background="#FF1E1E2A" Margin="0"/>

            <!-- ── 4 EC Paradigms ───────────────────────────────────────── -->
            <StackPanel Margin="40,36,40,0">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="Evolutionary Computation" FontSize="18" FontWeight="Bold"
                               Foreground="White"/>
                    <Border Margin="12,3,0,0" Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1"
                            CornerRadius="4" Padding="8,2" VerticalAlignment="Center">
                        <TextBlock Text="4 CANONICAL PARADIGMS" FontSize="9" FontWeight="SemiBold"
                                   Foreground="#FF64748B"/>
                    </Border>
                </StackPanel>

                <TextBlock FontSize="12" Foreground="#FF64748B" Margin="0,0,0,24" MaxWidth="700" TextWrapping="Wrap"
                           Text="In den 1960er und 1970er Jahren versuchten mehrere Wissenschaftler unabhängig voneinander, Konzepte der Evolution auf die Informatik anzuwenden. Die vier Hauptformen des Evolutionären Rechnens sind:"/>

                <UniformGrid Columns="4" Rows="1">

                    <!-- Genetic Algorithms -->
                    <Border Margin="0,0,10,0" CornerRadius="8"
                            Background="#FF111116" BorderThickness="1,1,1,3"
                            BorderBrush="#FF2A2A3A">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="BorderBrush" Value="#FF444455"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Margin="18,18,18,20">
                            <Border Width="36" Height="36" CornerRadius="4"
                                    Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1"
                                    HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="GA" FontSize="11" FontWeight="Bold"
                                           Foreground="#FF94A3B8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Genetic Algorithm" FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#FF475569"
                                       Text="JOHN HENRY HOLLAND  ·  1962" Margin="0,0,0,10"/>
                            <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="18"
                                       Text="Binary, real-valued and permutation chromosomes. Fixed-length encoding, selection · crossover · mutation pipeline."/>
                            <TextBlock Margin="0,12,0,0" FontSize="11" FontStyle="Italic" Foreground="#FF475569"
                                       TextWrapping="Wrap"
                                       Text='"Adaptation in Natural and Artificial Systems" (1975)'/>
                            <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                    Background="#FF7C3AED" HorizontalAlignment="Left" Width="40"/>
                        </StackPanel>
                    </Border>

                    <!-- Genetic Programming -->
                    <Border Margin="5,0,5,0" CornerRadius="8"
                            Background="#FF111116" BorderThickness="1,1,1,3"
                            BorderBrush="#FF2A2A3A">
                        <StackPanel Margin="18,18,18,20">
                            <Border Width="36" Height="36" CornerRadius="4"
                                    Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1"
                                    HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="GP" FontSize="11" FontWeight="Bold" Foreground="#FF94A3B8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Genetic Programming" FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#FF475569"
                                       Text="R.M. FRIEDBERG 1958  ·  KOZA 1992" Margin="0,0,0,10"/>
                            <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="18"
                                       Text="Tree-structured programs as genomes. Subtree crossover, constant perturbation. Symbolic regression, formula discovery."/>
                            <TextBlock Margin="0,12,0,0" FontSize="11" FontStyle="Italic" Foreground="#FF475569"
                                       TextWrapping="Wrap"
                                       Text='"Genetic Programming" — John Koza (1992)'/>
                            <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                    Background="#FF22C55E" HorizontalAlignment="Left" Width="40"/>
                        </StackPanel>
                    </Border>

                    <!-- Evolution Strategies -->
                    <Border Margin="5,0,5,0" CornerRadius="8"
                            Background="#FF111116" BorderThickness="1,1,1,3"
                            BorderBrush="#FF2A2A3A">
                        <StackPanel Margin="18,18,18,20">
                            <Border Width="36" Height="36" CornerRadius="4"
                                    Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1"
                                    HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="ES" FontSize="11" FontWeight="Bold" Foreground="#FF94A3B8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Evolution Strategies" FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#FF475569"
                                       Text="RECHENBERG &amp; SCHWEFEL  ·  1964 / 1973" Margin="0,0,0,10"/>
                            <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="18"
                                       Text="Real-valued vectors with self-adaptive step sizes. Gaussian mutation. (μ+λ) and (μ,λ) selection. Ackley, Sphere, Rastrigin."/>
                            <TextBlock Margin="0,12,0,0" FontSize="11" FontStyle="Italic" Foreground="#FF475569"
                                       TextWrapping="Wrap"
                                       Text='"Evolutionsstrategie" — Rechenberg, PhD 1973'/>
                            <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                    Background="#FFF59E0B" HorizontalAlignment="Left" Width="40"/>
                        </StackPanel>
                    </Border>

                    <!-- Evolutionary Programming -->
                    <Border Margin="10,0,0,0" CornerRadius="8"
                            Background="#FF111116" BorderThickness="1,1,1,3"
                            BorderBrush="#FF2A2A3A">
                        <StackPanel Margin="18,18,18,20">
                            <Border Width="36" Height="36" CornerRadius="4"
                                    Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1"
                                    HorizontalAlignment="Left" Margin="0,0,0,12">
                                <TextBlock Text="EP" FontSize="11" FontWeight="Bold" Foreground="#FF94A3B8"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Evolutionary Programming" FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,4"/>
                            <TextBlock FontSize="10" FontWeight="SemiBold" Foreground="#FF475569"
                                       Text="LAWRENCE J. FOGEL  ·  1966" Margin="0,0,0,10"/>
                            <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="18"
                                       Text="Evolution of finite state machines and behaviours. No crossover — mutation only. Tournament selection between parents and offspring."/>
                            <TextBlock Margin="0,12,0,0" FontSize="11" FontStyle="Italic" Foreground="#FF475569"
                                       TextWrapping="Wrap"
                                       Text='"Artificial Intelligence through Simulated Evolution" (1966)'/>
                            <Border Margin="0,14,0,0" Height="3" CornerRadius="2"
                                    Background="#FF38BDF8" HorizontalAlignment="Left" Width="40"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>
            </StackPanel>

            <!-- ── Playground cards ─────────────────────────────────────── -->
            <StackPanel Margin="40,32,40,40">
                <TextBlock Text="Playgrounds" FontSize="15" FontWeight="SemiBold"
                           Foreground="White" Margin="0,0,0,16"/>
                <WrapPanel Orientation="Horizontal">

                    <!-- TSP card -->
                    <Border CornerRadius="8" Background="#FF111116" BorderBrush="#FF7C3AED"
                            BorderThickness="1" Width="480" Margin="0,0,16,16">
                        <Grid Margin="24,20,24,20">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Traveling Salesperson Problem" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock FontSize="11" Foreground="#FF7C3AED" FontWeight="SemiBold"
                                           Text="ALL 4 EC PARADIGMS  ·  PERMUTATION GENOME" Margin="0,0,0,10"/>
                                <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="20"
                                           Text="Run GA, Evolution Strategies, Evolutionary Programming, or GP on the same TSP instance. Right-click the map to place cities, choose your paradigm and operators, then watch populations converge."/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Border Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                        <TextBlock Text="Right-click → Add City" FontSize="10" Foreground="#FF64748B"/>
                                    </Border>
                                    <Border Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="Distance matrix" FontSize="10" Foreground="#FF64748B"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Row="1" Content="▶  Open TSP Playground" Style="{StaticResource PrimaryButton}"
                                    HorizontalAlignment="Left" Margin="0,16,0,0" FontSize="12" Padding="18,8"
                                    Command="{Binding GoToTspCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Maze card -->
                    <Border CornerRadius="8" Background="#FF111116" BorderBrush="#FF22C55E"
                            BorderThickness="1" Width="480" Margin="0,0,16,16">
                        <Grid Margin="24,20,24,20">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Maze Solver" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock FontSize="11" Foreground="#FF22C55E" FontWeight="SemiBold"
                                           Text="GENETIC ALGORITHM  ·  DIRECTION-SEQUENCE GENOME" Margin="0,0,0,10"/>
                                <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="20"
                                           Text="A population of agents each encodes a fixed-length sequence of moves (N/E/S/W). GA evolves them toward the goal using tournament selection, two-point crossover, and per-gene mutation. Watch the best path improve generation by generation."/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Border Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                        <TextBlock Text="Perfect-maze generator" FontSize="10" Foreground="#FF64748B"/>
                                    </Border>
                                    <Border Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="Live path visualisation" FontSize="10" Foreground="#FF64748B"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Row="1" Content="▶  Open Maze Playground" Style="{StaticResource OutlineButton}"
                                    HorizontalAlignment="Left" Margin="0,16,0,0" FontSize="12" Padding="18,8"
                                    Command="{Binding GoToMazeCommand}"/>
                        </Grid>
                    </Border>

                    <!-- Blueprint card -->
                    <Border CornerRadius="8" Background="#FF111116" BorderBrush="#FFF59E0B"
                            BorderThickness="1" Width="480" Margin="0,0,16,16">
                        <Grid Margin="24,20,24,20">
                            <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                            <StackPanel>
                                <TextBlock Text="Blueprint Editor" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,6"/>
                                <TextBlock FontSize="11" Foreground="#FFF59E0B" FontWeight="SemiBold"
                                           Text="DRAG &amp; DROP BLOCKS" Margin="0,0,0,10"/>
                                <TextBlock FontSize="12" Foreground="#FF94A3B8" TextWrapping="Wrap" LineHeight="20"
                                           Text="Compose evolution pipelines from blocks. Drag GenomeSource, Crossover, Mutation, Selection, Fitness, Terminator. Connect output ports to input ports. Create new playgrounds without writing code."/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Border Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,3" Margin="0,0,6,0">
                                        <TextBlock Text="Categorical block palette" FontSize="10" Foreground="#FF64748B"/>
                                    </Border>
                                    <Border Background="#11FFFFFF" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4" Padding="8,3">
                                        <TextBlock Text="Port connections" FontSize="10" Foreground="#FF64748B"/>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                            <Button Grid.Row="1" Content="▶  Open Blueprint Editor" Style="{StaticResource OutlineButton}"
                                    HorizontalAlignment="Left" Margin="0,16,0,0" FontSize="12" Padding="18,8"
                                    Command="{Binding GoToBlueprintCommand}"/>
                        </Grid>
                    </Border>

                </WrapPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
