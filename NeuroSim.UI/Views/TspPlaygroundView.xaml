<!-- AUTH:DEVNEUROSIM:7A3F9E2B | Legacy/NeuroSim.UI/Views/TspPlaygroundView.xaml -->
<UserControl x:Class="NeuroSim.UI.Views.TspPlaygroundView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:NeuroSim.UI.ViewModels"
             xmlns:local="clr-namespace:NeuroSim.UI.Views">

    <UserControl.Resources>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground"  Value="#475569"/>
            <Setter Property="FontSize"    Value="10"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Margin"      Value="0,0,0,4"/>
        </Style>
        <Style x:Key="Desc" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#64748B"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight"   Value="17"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"     Value="#111118"/>
            <Setter Property="BorderBrush"    Value="#252535"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="6"/>
            <Setter Property="Padding"        Value="10,8"/>
        </Style>

        <!-- TabControl dark style -->
        <Style x:Key="DarkTab" TargetType="TabControl">
            <Setter Property="Background"           Value="#09090F"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="Padding"              Value="0"/>
        </Style>
        <Style x:Key="DarkTabItem" TargetType="TabItem">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="Foreground"   Value="#64748B"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Padding"      Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="Transparent"
                                BorderThickness="0,0,0,2" BorderBrush="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#7C3AED"/>
                                <Setter Property="Foreground" Value="#F1F5F9"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!-- Root: left config + right tabs -->
    <Grid Background="#0A0A0F">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════
             LEFT: CONFIG PANEL
        ═════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="#0D0D15" BorderBrush="#1E1E2E" BorderThickness="0,0,1,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14,14,14,20">

                    <TextBlock Text="DATASET" Style="{StaticResource Lbl}"/>
                    <ComboBox ItemsSource="{Binding Presets}"
                              SelectedItem="{Binding SelectedPreset}"
                              Margin="0,0,0,10"/>

                    <TextBlock Text="PARADIGM" Style="{StaticResource Lbl}"/>
                    <ComboBox ItemsSource="{Binding Paradigms}"
                              SelectedItem="{Binding SelectedParadigm}"
                              Margin="0,0,0,6"/>
                    <Border Background="#0F0F1A" BorderBrush="#1E2030" BorderThickness="1"
                            CornerRadius="5" Padding="9,7" Margin="0,0,0,12">
                        <TextBlock Text="{Binding ParadigmDesc}" Style="{StaticResource Desc}" Margin="0"/>
                    </Border>

                    <TextBlock Text="SELECTION" Style="{StaticResource Lbl}"/>
                    <ComboBox ItemsSource="{Binding AvailableSelections}"
                              SelectedItem="{Binding SelectedSelection}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding SelectionDesc}" Style="{StaticResource Desc}"/>

                    <TextBlock Text="CROSSOVER" Style="{StaticResource Lbl}"/>
                    <ComboBox ItemsSource="{Binding AvailableCrossovers}"
                              SelectedItem="{Binding SelectedCrossover}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding CrossoverDesc}" Style="{StaticResource Desc}"/>

                    <TextBlock Text="MUTATION" Style="{StaticResource Lbl}"/>
                    <ComboBox ItemsSource="{Binding AvailableMutations}"
                              SelectedItem="{Binding SelectedMutation}"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding MutationDesc}" Style="{StaticResource Desc}"/>

                    <StackPanel Visibility="{Binding ShowEsOptions, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="ES STRATEGY" Style="{StaticResource Lbl}"/>
                        <ComboBox ItemsSource="{Binding EsStrategies}"
                                  SelectedItem="{Binding EsStrategy}"
                                  Margin="0,0,0,10"/>
                    </StackPanel>

                    <Separator Background="#1A1A28" Margin="0,2,0,10"/>

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="POPULATION" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding PopulationSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="GENERATIONS" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding MaxGenerations, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="MUT. RATE" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding MutationRate, UpdateSourceTrigger=PropertyChanged, StringFormat=P0}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="CROSS. RATE" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding CrossoverRate, UpdateSourceTrigger=PropertyChanged, StringFormat=P0}"/>
                        </StackPanel>
                    </Grid>
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="TOURN. K" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding TournamentSize, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="SEED" Style="{StaticResource Lbl}"/>
                            <TextBox Text="{Binding RandomSeed, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Separator Background="#1A1A28" Margin="0,2,0,10"/>

                    <!-- Speed control -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="SPEED" Style="{StaticResource Lbl}" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        <TextBlock Text="{Binding SpeedLabel}" Foreground="#7C3AED"
                                   FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>
                    <Slider Minimum="0" Maximum="2000" Value="{Binding SpeedDelayMs}"
                            TickFrequency="100" IsSnapToTickEnabled="True"
                            Margin="0,0,0,2" Foreground="#7C3AED"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Fast" Foreground="#334155" FontSize="9" HorizontalAlignment="Left"/>
                        <TextBlock Text="Slow" Foreground="#334155" FontSize="9"
                                   HorizontalAlignment="Right" Margin="140,0,0,0"/>
                    </StackPanel>

                    <Separator Background="#1A1A28" Margin="0,2,0,10"/>

                    <!-- Run controls -->
                    <Button Content="▶  RUN EVOLUTION" Style="{StaticResource PrimaryButton}"
                            Padding="0,9" FontSize="13" Command="{Binding RunCommand}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="■  Stop"  Style="{StaticResource DangerButton}"
                                Padding="0,7" FontSize="12" Command="{Binding StopCommand}"/>
                        <Button Grid.Column="2" Content="↺  Reset" Style="{StaticResource OutlineButton}"
                                Padding="0,7" FontSize="12" Command="{Binding ResetCommand}"/>
                    </Grid>
                    <Button Content="✕  Clear Cities" Style="{StaticResource GhostButton}"
                            Padding="0,7" FontSize="12" Margin="0,6,0,0"
                            Command="{Binding ClearCommand}" HorizontalAlignment="Stretch"/>
                    <Separator Background="#1A1A28" Margin="0,10,0,10"/>

                    <!-- Snapshot -->
                    <TextBlock Text="SNAPSHOT NAME" Style="{StaticResource Lbl}"/>
                    <TextBox Text="{Binding SnapshotName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="6"/><ColumnDefinition/></Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="💾  Save" Style="{StaticResource OutlineButton}"
                                Padding="0,7" FontSize="12" Command="{Binding SaveSnapshotCommand}"/>
                        <Button Grid.Column="2" Content="📂  Load" Style="{StaticResource GhostButton}"
                                Padding="0,7" FontSize="12" Command="{Binding LoadSnapshotCommand}"
                                HorizontalAlignment="Stretch"/>
                    </Grid>

                    <!-- Loaded snapshot info -->
                    <Border Visibility="{Binding HasLoadedSnapshot, Converter={StaticResource BoolToVisibility}}"
                            Background="#0F1A0F" BorderBrush="#1A2E1A" BorderThickness="1"
                            CornerRadius="5" Padding="9,7" Margin="0,8,0,0">
                        <TextBlock Text="{Binding LoadedSnapshotInfo}" Foreground="#4ADE80"
                                   FontSize="10" TextWrapping="Wrap"/>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════
             RIGHT: TAB AREA
        ═════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- tab bar + progress -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <Border Grid.Row="0" Background="#0D0D15" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
                <Grid>
                    <TabControl x:Name="MainTabCtrl"
                                Style="{StaticResource DarkTab}"
                                Background="Transparent"
                                BorderThickness="0">
                        <TabControl.Template>
                            <ControlTemplate TargetType="TabControl">
                                <StackPanel Orientation="Horizontal">
                                    <TabPanel IsItemsHost="True" Background="Transparent"/>
                                </StackPanel>
                            </ControlTemplate>
                        </TabControl.Template>
                        <TabItem Header="  Map  "       Style="{StaticResource DarkTabItem}" Tag="map"/>
                        <TabItem Header="  Analysis  "  Style="{StaticResource DarkTabItem}" Tag="analysis"/>
                        <TabItem Header="  Reference  " Style="{StaticResource DarkTabItem}" Tag="ref"/>
                    </TabControl>
                    <!-- Map toolbar right side -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,12,0">
                        <Button x:Name="ExportMapBtn" Content="💾 Export Map" Style="{StaticResource GhostButton}"
                                Padding="10,5" FontSize="11" Margin="0,0,8,0"
                                Click="ExportMapBtn_OnClick"/>
                        <Button Content="＋  Add City" Style="{StaticResource OutlineButton}"
                                Padding="10,5" FontSize="11" Command="{Binding AddCityCommand}"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Status}" Foreground="#475569"
                                   FontSize="11" VerticalAlignment="Center" MaxWidth="340"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tab content area -->
            <Grid Grid.Row="1">

                <!-- MAP tab -->
                <Grid x:Name="MapPane">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="3"/>
                    </Grid.RowDefinitions>
                    <local:InteractiveTspCanvas x:Name="TspCanvas"
                                                DataContext="{Binding}"
                                                Background="#09090F"
                                                ClipToBounds="True"/>
                    <ProgressBar Grid.Row="1" Value="{Binding ProgressPct}" Maximum="100"
                                 Background="#0A0A0F" Foreground="#7C3AED" BorderThickness="0"/>
                </Grid>

                <!-- ANALYSIS tab (hidden by default) -->
                <local:PlaygroundAnalysisView x:Name="AnalysisPane" Visibility="Collapsed"
                                             StatBadges="{Binding StatBadges}"
                                             Charts="{Binding Charts}"
                                             DataContext="{Binding}">
                    <local:PlaygroundAnalysisView.ExtraContent>
                        <StackPanel>
                        <!-- Genome display (modular, reusable) -->
                        <local:GenomeDisplayView DataContext="{Binding GenomeDisplay}" Margin="0,0,0,16"/>
                        <!-- Distance matrix -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="PAIRWISE DISTANCE MATRIX"
                                       Foreground="#475569" FontSize="10" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="(first 20 cities · sorted by distance)"
                                       Foreground="#1E2A3A" FontSize="10" Margin="8,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <CheckBox Content="Show distance matrix" IsChecked="{Binding ShowDistanceMatrix}"
                                  Foreground="#64748B" FontSize="11" Margin="0,0,0,8"/>
                        <StackPanel Visibility="{Binding ShowDistanceMatrix, Converter={StaticResource BoolToVisibility}}">
                            <DataGrid ItemsSource="{Binding DistanceRows}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="#0A0A0F" Foreground="#94A3B8"
                                      BorderBrush="#1E1E2E" GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#1A1A28"
                                      ColumnHeaderHeight="28" RowHeight="24"
                                      FontSize="11" MaxHeight="320" Margin="0,0,0,20">
                                <DataGrid.ColumnHeaderStyle>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#0D0D18"/>
                                        <Setter Property="Foreground" Value="#475569"/>
                                        <Setter Property="FontSize"   Value="10"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding"    Value="8,0"/>
                                    </Style>
                                </DataGrid.ColumnHeaderStyle>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="From" Binding="{Binding From}" Width="70"/>
                                    <DataGridTextColumn Header="To"   Binding="{Binding To}"   Width="70"/>
                                    <DataGridTextColumn Header="Distance" Binding="{Binding Distance}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>

                        <!-- Paradigm reference  -->
                        <TextBlock Text="PARADIGM COMPARISON" Foreground="#475569" FontSize="10"
                                   FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/><ColumnDefinition Width="8"/>
                                <ColumnDefinition/><ColumnDefinition Width="8"/><ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="#111118" BorderBrush="#7C3AED" BorderThickness="0,0,0,2" CornerRadius="5" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="GA" Foreground="#A78BFA" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="Select + Crossover + Mutate" Foreground="#475569" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="#111118" BorderBrush="#22C55E" BorderThickness="0,0,0,2" CornerRadius="5" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="ES" Foreground="#22C55E" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="(μ+λ) / (μ,λ)  Adaptive σ" Foreground="#475569" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="4" Background="#111118" BorderBrush="#F59E0B" BorderThickness="0,0,0,2" CornerRadius="5" Padding="10,8">
                                <StackPanel>
                                    <TextBlock Text="EP" Foreground="#F59E0B" FontSize="10" FontWeight="Bold"/>
                                    <TextBlock Text="No crossover · Full pool tournament" Foreground="#475569" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Background="#111118" BorderBrush="#38BDF8" BorderThickness="0,0,0,2"
                                CornerRadius="5" Padding="10,8" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="GP" Foreground="#38BDF8" FontSize="10" FontWeight="Bold"/>
                                <TextBlock Text="Evolves greedy-heuristic weight vector · BLX-α crossover · Gaussian mutation · Nearest-neighbour tour construction" Foreground="#475569" FontSize="10" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        </StackPanel>
                    </local:PlaygroundAnalysisView.ExtraContent>
                </local:PlaygroundAnalysisView>

                <!-- REFERENCE tab -->
                <ScrollViewer x:Name="RefPane" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto" Background="#0A0A0F">
                    <StackPanel Margin="24,18,24,24">
                        <TextBlock Text="OPERATOR REFERENCE" Foreground="#475569" FontSize="10"
                                   FontWeight="SemiBold" Margin="0,0,0,14"/>

                        <!-- Selection -->
                        <Border Background="#111118" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="SELECTION METHODS" Foreground="#A78BFA" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18"
                                           Text="Tournament (k): Sample k random individuals; the fittest wins. Controls selection pressure via k."/>
                                <TextBlock Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,0"
                                           Text="Roulette Wheel: Fitness-proportionate selection. High variance — super-individuals can dominate."/>
                                <TextBlock Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18" Margin="0,6,0,0"
                                           Text="Rank-Based: Selection ∝ rank, not raw fitness. Avoids dominance; maintains diversity."/>
                            </StackPanel>
                        </Border>

                        <!-- Crossover ASCII diagrams -->
                        <Border Background="#111118" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="ORDER CROSSOVER (OX)" Foreground="#22C55E" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#64748B">
P1:  1  2 [3  4  5] 6  7  8<LineBreak/>
P2:  3  7  8  2  4  1  6  5<LineBreak/>
                              ↓ copy segment, fill from P2 order<LineBreak/>
C1:  7  8 [3  4  5] 2  1  6
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#111118" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="2-OPT MUTATION" Foreground="#F59E0B" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#64748B">
Before: A → B → C → D → E → F<LineBreak/>
              ↑           ↑<LineBreak/>
              reverse segment i..j<LineBreak/>
After:  A → B → E → D → C → F
                                </TextBlock>
                                <TextBlock Foreground="#475569" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"
                                           Text="Removes crossing edges. One of the most effective TSP local search moves."/>
                            </StackPanel>
                        </Border>

                        <Border Background="#111118" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="6" Padding="14,12" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="OR-OPT MUTATION" Foreground="#38BDF8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock FontFamily="Consolas" FontSize="11" Foreground="#64748B">
Before: A → [B  C] → D → E → F<LineBreak/>
              ↑↑↑ relocate chain<LineBreak/>
After:  A → D → E → [B  C] → F
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Background="#111118" BorderBrush="#1E1E2E" BorderThickness="1" CornerRadius="6" Padding="14,12">
                            <StackPanel>
                                <TextBlock Text="GP WEIGHT-VECTOR ENCODING" Foreground="#38BDF8" FontSize="10" FontWeight="Bold" Margin="0,0,0,8"/>
                                <TextBlock Foreground="#94A3B8" FontSize="11" TextWrapping="Wrap" LineHeight="18"
                                           Text="Each GP individual is a real-valued vector w[0..N-1]. Tour construction: from city i, choose unvisited j = argmax(w[j] / dist(i,j)). This evolves the 'attractiveness' of each city. BLX-α crossover blends weight vectors; Gaussian noise mutates them."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

            </Grid>

            <!-- Tab switcher logic via code-behind -->
            <Border Grid.Row="1" x:Name="TabSwitcherOverlay" Visibility="Collapsed"/>

        </Grid>
    </Grid>
</UserControl>
